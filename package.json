{
  "name": "contribux",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "type-check": "tsc --noEmit --incremental false",
    "deps:outdated:ci": "node scripts/check-compatible-outdated.mjs",
    "test": "pnpm test:unit && pnpm test:security",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:db": "vitest run --config vitest.database.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:ci": "vitest run --config vitest.integration.config.ts --reporter=verbose --bail=1",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ci": "playwright test --reporter=line",
    "test:unit": "vitest run --run tests/unit/api/health.test.ts tests/unit/api/search-api.test.ts tests/unit/github/comprehensive tests/unit/search/functions tests/unit/middleware.test.ts",
    "test:unit:enhanced": "pnpm test:unit",
    "test:security": "vitest run --config vitest.config.ts tests/security/database-security.test.ts tests/security/headers.test.ts tests/security/csp.test.ts",
    "test:db:enhanced": "vitest run --config vitest.database.config.ts",
    "test:integration:enhanced": "vitest run --config vitest.integration.config.ts",
    "test:all:enhanced": "pnpm test:unit:enhanced && pnpm test:db:enhanced && pnpm test:integration:enhanced",
    "playwright:install": "playwright install --with-deps",
    "db:setup": "bash scripts/setup-local-db.sh",
    "db:test-connection": "node scripts/db-migrations/run-migrations-enhanced.cjs status",
    "db:migrate": "node scripts/db-migrations/run-migrations-enhanced.cjs run",
    "db:migrate:test": "NODE_ENV=test node scripts/db-migrations/run-migrations-enhanced.cjs run",
    "db:migrate:status": "node scripts/db-migrations/run-migrations-enhanced.cjs status",
    "db:migrate:reset": "node scripts/db-migrations/run-migrations-enhanced.cjs reset",
    "db:health": "node -e \"console.log('Database health check...')\"",
    "db:performance-report": "node -e \"console.log('Performance report...')\"",
    "db:vector-metrics": "node -e \"console.log('Vector metrics...')\"",
    "perf:analyze": "node scripts/performance-analysis.js",
    "perf:bundle": "node scripts/bundle-analyzer.js",
    "perf:report": "pnpm perf:analyze && pnpm perf:bundle",
    "analyze": "ANALYZE=true next build",
    "analyze:server": "BUNDLE_ANALYZE=server next build",
    "analyze:browser": "BUNDLE_ANALYZE=browser next build",
    "perf:dashboard": "echo 'Visit /performance in your app to view the performance dashboard'",
    "observability:up": "docker-compose -f docker-compose.observability.yml up -d",
    "observability:down": "docker-compose -f docker-compose.observability.yml down",
    "observability:logs": "docker-compose -f docker-compose.observability.yml logs -f",
    "observability:status": "docker-compose -f docker-compose.observability.yml ps",
    "health:check": "curl -s http://localhost:3000/api/health | jq",
    "metrics:view": "curl -s http://localhost:3000/api/metrics"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "@octokit/types": "^16.0.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.75.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.217.0",
    "@opentelemetry/exporter-prometheus": "0.217.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.217.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.217.0",
    "@opentelemetry/instrumentation": "0.217.0",
    "@opentelemetry/instrumentation-express": "0.65.0",
    "@opentelemetry/instrumentation-fs": "0.36.0",
    "@opentelemetry/instrumentation-http": "0.217.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-metrics": "2.7.1",
    "@opentelemetry/sdk-node": "0.217.0",
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@redis/client": "^5.12.1",
    "@simplewebauthn/server": "^13.3.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.100.9",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "ipaddr.js": "^2.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "radix-ui": "^1.4.3",
    "rate-limiter-flexible": "^11.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@electric-sql/pglite": "^0.4.5",
    "@faker-js/faker": "^10.4.0",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "1.59.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.40",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "glob": "^13.0.6",
    "jsdom": "^29.1.1",
    "msw": "^2.14.5",
    "next-test-api-route-handler": "^5.0.5",
    "postcss": "^8.5.14",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "undici": "^8.2.0",
    "vite": "8.0.11",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": "0.27.7",
      "postcss": "8.5.14"
    }
  }
}
